{
  "branches": [
    "main",
    {"name": "beta", "prerelease": true}
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "make rock-artifacts VERSION=${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "cerulean-*-1.rockspec",
            "label": "cerulean rockspec"
          },
          {
            "path": "cerulean-*.tar.gz",
            "label": "cerulean source tarball"
          }
        ]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "echo '${nextRelease.version}' | grep -qv '\\-' && luarocks upload cerulean-${nextRelease.version}-1.rockspec --api-key=$LUAROCKS_API_KEY"
      }
    ]
  ]
}
